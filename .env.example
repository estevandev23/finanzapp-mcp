# Configuración de FinanzApp MCP Server

# URL base del API de FinanzApp
FINANZAPP_API_URL=http://localhost:8080/api/v1

# Token JWT para autenticación (obtener mediante login)
FINANZAPP_JWT_TOKEN=

# Número de WhatsApp del usuario (opcional, para autenticación WhatsApp)
FINANZAPP_WHATSAPP_NUMBER=

# Timeout para requests en milisegundos
FINANZAPP_TIMEOUT=30000
