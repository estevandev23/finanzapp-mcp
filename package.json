{
  "name": "finanzapp-mcp",
  "version": "1.0.0",
  "description": "MCP Server para Asistente Financiero Personal - FinanzApp",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http-server.js",
    "start:sse": "node dist/sse-server.js",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/http-server.ts",
    "dev:sse": "tsx src/sse-server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @anthropics/mcp-inspector dist/index.js"
  },
  "keywords": [
    "mcp",
    "finanzas",
    "claude",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "express": "^5.2.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
